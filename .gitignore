# 依赖目录
node_modules/
.pnpm-store/

# 构建产物
dist/
build/
.vite/

# 环境变量（绝对不上传）
.env
.env.local
.env.production
server/.env

# 数据库文件（用户私人数据）
server/data/*.db
server/data/*.db-shm
server/data/*.db-wal

# 用户上传的数据文件（私人数据）
server/data/characters/
server/data/worlds/
server/data/presets/

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 编辑器配置
.idea/
*.swp
*.swo

# 日志
*.log
logs/

# TypeScript 缓存
*.tsbuildinfo
