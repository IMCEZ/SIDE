# =============================================
# SIDE 环境变量配置模板
# 使用方法：
#   将本文件复制为 .env（去掉 .example 后缀）
#   然后修改下方的配置项
# =============================================

# 【必填】JWT 密钥
# 用于加密你的登录凭证，保护聊天记录隐私
# 请替换为任意一段随机字符串，越长越安全，建议32位以上
# 示例：JWT_SECRET=aK9#mP2$xQ8nL5vR3wY7tZ1bC6dE4fH0
JWT_SECRET=请替换为随机字符串

# 【可选】服务器端口，默认 3000，一般不需要修改
PORT=3000

# 【可选】运行环境，保持 development 即可
NODE_ENV=development
